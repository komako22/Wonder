<Window x:Class="GlassTranslate.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="720" Height="560" WindowStyle="None" ResizeMode="NoResize"
        Background="#EFEEF3FA" WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Border CornerRadius="22" BorderBrush="#8AFFFFFF" BorderThickness="1" Padding="26">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F4F7FAFF" Offset="0"/>
                <GradientStop Color="#ECEDF2FA" Offset="0.55"/>
                <GradientStop Color="#E8E3E9FA" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="22" Background="#207C9CFF">
                        <Image Source="/Assets/Wonder.png" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Wonder" FontSize="21" FontWeight="SemiBold" Foreground="#182238"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="×" Width="32" Height="32" Padding="0" FontSize="18"
                        Foreground="#33415E" Click="Close_OnClick"/>
            </Grid>

            <TabControl Grid.Row="1" Margin="0,22,0,18" Background="#34FFFFFF" BorderBrush="#4AFFFFFF">
                <TabItem Header="划词">
                    <StackPanel Margin="18">
                        <TextBlock Text="选区读取方式" Foreground="#59657B" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SelectionMethodBox" Padding="8,6" DisplayMemberPath="Name"/>
                        <TextBlock Text="自动兼容仅使用 UI Automation，不会模拟 Ctrl+C 或修改剪贴板。"
                                   Foreground="#78849A" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,20"/>
                        <TextBlock Text="气泡响应延迟" Foreground="#59657B"/>
                        <Slider x:Name="DelaySlider" Minimum="0.08" Maximum="0.60" TickFrequency="0.02"
                                IsSnapToTickEnabled="True" Margin="0,8,0,4"/>
                        <TextBlock Text="建议 0.18 秒；太短会在拖动过程中误触发。" Foreground="#78849A" FontSize="12"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="翻译">
                    <StackPanel Margin="18">
                        <TextBlock Text="免费翻译（无需密钥）" Foreground="#33415E" FontWeight="SemiBold"/>
                        <StackPanel Margin="0,14,0,0">
                            <TextBox x:Name="FreeEmailBox" ToolTip="选填：用于提升免费额度"/>
                            <TextBlock Text="免费服务无需密钥；匿名每天 5,000 字符，填写有效邮箱后每天 50,000 字符。"
                                       Foreground="#78849A" FontSize="12" TextWrapping="Wrap" Margin="0,7,0,0"/>
                        </StackPanel>
                        <TextBlock Text="目标语言" Foreground="#59657B" Margin="0,16,0,6"/>
                        <ComboBox x:Name="LanguageBox" Padding="8,6" DisplayMemberPath="Name"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="气泡与外观">
                    <StackPanel Margin="18">
                        <TextBlock Text="气泡位置" Foreground="#59657B" Margin="0,0,0,6"/>
                        <ComboBox x:Name="BubblePositionBox" Padding="8,6" DisplayMemberPath="Name"/>
                        <TextBlock Text="气泡大小" Foreground="#59657B" Margin="0,16,0,0"/>
                        <Slider x:Name="BubbleScaleSlider" Minimum="0.8" Maximum="1.5" TickFrequency="0.05"
                                IsSnapToTickEnabled="True" Margin="0,8"/>
                        <TextBlock Text="玻璃主题" Foreground="#59657B" Margin="0,10,0,6"/>
                        <ComboBox x:Name="ThemeBox" Padding="8,6" DisplayMemberPath="Name"/>
                        <CheckBox x:Name="ShowSourceBox" Content="翻译卡片显示原文" Foreground="#33415E" Margin="0,16,0,0"/>
                        <TextBlock Text="译文字号" Foreground="#59657B" Margin="0,14,0,0"/>
                        <Slider x:Name="FontSizeSlider" Minimum="13" Maximum="22" TickFrequency="1"
                                IsSnapToTickEnabled="True" Margin="0,8"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="启动">
                    <StackPanel Margin="18">
                        <CheckBox x:Name="LaunchAtLoginBox" Content="登录 Windows 后自动启动" Foreground="#33415E"/>
                        <TextBlock Text="关闭设置窗口后，Wonder 仍在系统托盘后台运行。"
                                   Foreground="#78849A" FontSize="12" Margin="0,12,0,0"/>
                        <TextBlock Text="不会保存翻译历史；只有点击气泡后才会向翻译服务发送选中文本。"
                                   Foreground="#78849A" FontSize="12" Margin="0,8,0,0"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <Grid Grid.Row="2">
                <TextBlock x:Name="StatusText" Foreground="#68748A" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="恢复推荐设置" Margin="0,0,8,0" Click="Restore_OnClick"/>
                    <Button Content="保存设置" MinWidth="92" Click="Save_OnClick"
                            Background="#FF627FE8" BorderBrush="#FF627FE8"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
