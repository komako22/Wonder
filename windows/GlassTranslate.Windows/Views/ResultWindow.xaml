<Window x:Class="GlassTranslate.Windows.Views.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="270" WindowStyle="None" ResizeMode="NoResize"
        Background="#DD171C27" ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual">
    <Border CornerRadius="18" BorderBrush="#52FFFFFF" BorderThickness="1" Padding="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#D92A3242" Offset="0"/>
                <GradientStop Color="#DF171C27" Offset="0.55"/>
                <GradientStop Color="#D9222841" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Width="46" Height="5" CornerRadius="3"
                    Background="#55AEB7CB" HorizontalAlignment="Center" VerticalAlignment="Top"
                    Cursor="SizeAll" MouseLeftButtonDown="DragHandle_OnMouseLeftButtonDown"/>

            <StackPanel x:Name="SourcePanel" Grid.Row="1" Margin="0,0,32,10">
                <TextBlock Text="原文" FontSize="11" Foreground="#AEB7CB" Margin="0,0,0,6"/>
                <TextBlock x:Name="SourceText" FontSize="13" Foreground="#BFC7D8"
                           TextWrapping="Wrap" MaxHeight="46" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Grid.Row="2" Height="1" Background="#2EFFFFFF"/>

            <Grid Grid.Row="3" Margin="0,10,0,0">
                <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" VerticalAlignment="Top">
                    <ProgressBar Width="48" Height="3" IsIndeterminate="True" Margin="0,8,10,0"/>
                    <TextBlock Text="正在翻译…" Foreground="#AEB7CB"/>
                </StackPanel>

                <Grid x:Name="ResultPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ResultText" FontSize="16" FontWeight="Medium" Foreground="#F5F7FF"
                                   TextWrapping="Wrap" LineStackingStrategy="BlockLineHeight"/>
                    </ScrollViewer>
                    <Button Grid.Row="1" Content="复制译文" HorizontalAlignment="Right" Margin="0,10,0,0"
                            Click="Copy_OnClick"/>
                </Grid>

                <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" VerticalAlignment="Top">
                    <TextBlock x:Name="ErrorText" Foreground="#FFFFA6A6" TextWrapping="Wrap"/>
                    <Button Content="重试" HorizontalAlignment="Left" Margin="0,12,0,0" Click="Retry_OnClick"/>
                </StackPanel>
            </Grid>

            <Button Content="×" Width="26" Height="26" Padding="0" FontSize="16"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="10"
                    Click="Close_OnClick"/>
        </Grid>
    </Border>
</Window>
