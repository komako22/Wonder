<Application x:Class="GlassTranslate.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AEB7CB"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C9CFF"/>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderBrush" Value="#32FFFFFF"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Foreground" Value="#162033"/>
            <Setter Property="Background" Value="#EAF2F7FF"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Foreground" Value="#162033"/>
            <Setter Property="Background" Value="#EAF2F7FF"/>
        </Style>
    </Application.Resources>
</Application>

